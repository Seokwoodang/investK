# ─────────────────────────────────────────────────────────────
# 모든 키는 선택사항입니다. 없으면 해당 영역은 목(mock) 데이터로 자동 폴백합니다.
# .env.local 로 복사해서 채워 넣으세요 (서버 전용 키는 절대 클라이언트에 노출 금지).
# ─────────────────────────────────────────────────────────────

# 한국투자증권 KIS Open API (국내주식 시세) — https://apiportal.koreainvestment.com
KIS_APP_KEY=
KIS_APP_SECRET=
# 실전계좌: https://openapi.koreainvestment.com:9443  /  모의투자: https://openapivts.koreainvestment.com:29443
KIS_BASE=https://openapi.koreainvestment.com:9443

# 해외주식 (둘 중 하나) — Finnhub: https://finnhub.io  /  Twelve Data: https://twelvedata.com
FINNHUB_KEY=
TWELVEDATA_KEY=

# 뉴스 — 네이버 검색 API: https://developers.naver.com
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Supabase (AI 분석 캐시 · 향후 관심종목 동기화) — https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude (데일리/차트 AI 생성) — https://console.anthropic.com
ANTHROPIC_API_KEY=
# 선택: 생성 모델 (기본 claude-sonnet-4-6, 최고 품질은 claude-opus-4-8)
ANTHROPIC_MODEL=claude-sonnet-4-6

# 로그인 — 회원가입 없음(아래 목록 계정만). 미설정 시 기본값: 아이디 swoo1427,squface,squface1427 / 비번 1234
APP_USERS=swoo1427,squface,squface1427
APP_PASS=1234
# 세션 쿠키 서명키 — 길고 랜덤한 값으로(예: openssl rand -hex 32). 미설정 시 코드의 기본값이 쓰여 위조 가능.
AUTH_SECRET=
